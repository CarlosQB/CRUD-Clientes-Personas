<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <title>Document</title>
</head>
<body>
<div class="container mt-4">
    <a href="/contacts/nuevo" class="btn btn-primary">Nuevo</a>
    <table class="table">
        <thead>
            <tr>
                <th>NOMBRE</th>
                <th>TELEFONO FIJO</th>
                <th>TELEFONO MOVIL</th>
                <th>TIPO CONTACTO</th>
                <th>VER CONTACTO</th>
                <th>EDITAR CONTACTO</th>
                <th>ELIMINAR CONTACTO</th>
            </tr>
        </thead>
        <tbody>
            <% contactos.forEach((contacto)=>{ %>
            <tr>
                <td><%= contacto.Nombre %></td>
                <td><%= contacto.TFijo %></td>
                <td><%= contacto.TMovil %></td>
                <td><%= contacto.TContacto %></td>
                <td><a href="/contacts/ver/<%= contacto.Id %>?desCamp=true"class="btn btn-success">Ver</a></td>
                <td><a href="/contacts/editar/<%= contacto.Id %>?desCamp=false" class="btn btn-info">Editar</a></td>
                <td><a href="/contacts/eliminar/<%= contacto.Id %>" class="btn btn-danger">Eliminar</a></td>
            </tr>
            <% }) %>
        </tbody>
    </table>
</div>
</body>
</html>