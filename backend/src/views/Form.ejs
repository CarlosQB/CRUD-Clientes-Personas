<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <title>Document</title>
</head>
<body>
<div class="container mt-4">
    <div class="col-sm-6">
        <form action="/contacts/<%= contacto ? contacto.Id : '' %>" method="post">
            <div class="card">
                <div class="card-header">
                    <h3>Contacto</h3>
                </div>
                <div class="card-body">
                    <div class="form-group">
                        <label>Nombre</label>
                        <input id="Nombre" name="Nombre" type="text" value="<%= contacto ? contacto.Nombre : '' %>" class="form-control" <%= cd ? 'disabled' : 'enable' %>>
                    </div>
                    <div class="form-group">
                        <label>Tipo Contacto</label>
                        <select id="TContacto" name="TContacto" type="text" value="<%= contacto ? contacto.TContacto : '' %>" class="form-control" <%= cd ? 'disabled' : 'enable' %>>
                            <option>Amistad</option>
                            <option>Familiar</option>
                            <option>Trabajo</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Telefono Fijo</label>
                        <input id="TFijo" name="TFijo" type="text" value="<%= contacto ? contacto.TFijo : '' %>" class="form-control" <%= cd ? 'disabled' : 'enable' %>>
                    </div>
                    <div class="form-group">
                        <label>Telefono movil</label>
                        <input id="TMovil" name="TMovil" type="text" value="<%= contacto ? contacto.TMovil : '' %>" class="form-control" <%= cd ? 'disabled' : 'enable' %>>
                    </div>
                    <div class="form-group">
                        <label>Fecha de nacimiento</label>
                        <input id="FechaN" name="FechaN" type="date" value="<%= contacto ? contacto.FechaN : '' %>" class="form-control" <%= cd ? 'disabled' : 'enable' %>>
                    </div>
                    <div class="form-group">
                        <label>Sexo</label>
                        <select id="Sexo" name="Sexo" type="text" value="<%= contacto ? contacto.Sexo : '' %>" class="form-control" <%= cd ? 'disabled' : 'enable' %>>
                            <option>Femenino</option>
                            <option>Masculino</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Estado civil</label>
                        <select id="EC" name="EC" type="text" value="<%= contacto ? contacto.EC : '' %>" class="form-control" <%= cd ? 'disabled' : 'enable' %>>
                            <option>Soltero</option>
                            <option>Casado</option>
                            <option>Divorciado</option>
                            <option>Unión Libre</option>
                            <option>Viudo</option>
                        </select>
                    </div>
                </div>
                    <div class="card-footer">
                        <button type="submit" class="btn btn-success">Guardar</button>
                    </div>
            </div>
        </form>
    </div>
</div>
</body>
</html>